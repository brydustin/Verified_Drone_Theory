session Applied_Math_Base in "Base" = "HOL-Complex_Analysis" +
  options [document = false, quick_and_dirty = true, timeout = 3600]
  sessions
    Munkres_Topology_Local
    Jordan_Normal_Form
    Perron_Frobenius
    "HOL-Types_To_Sets"
  theories
    Munkres_Topology_Local.Munkres_Topology
    "HOL-Complex_Analysis.Conformal_Mappings"
    "Perron_Frobenius.HMA_Connect"

session Applied_Math_BlockDet in "BlockDet" = Applied_Math_Base +
  options [document = false, quick_and_dirty = true, timeout = 3600]
  theories
    Block_Determinants
    Block_Determinants_BigJ
    Moment_Map

(* Moment_Jacobian (transports + the D_x M_paper = bigJ Jacobian identification)
   lives in its OWN session/dir, parented on Applied_Math_BlockDet, so it can be edited
   interactively with -l Applied_Math_BlockDet: its dependencies come from that
   heap while Moment_Jacobian itself is NOT in the heap (a theory under active
   editing must not be part of the logic image it is loaded against). *)
session Applied_Math_MomentJac in "MomentJac" = Applied_Math_BlockDet +
  options [document = false, quick_and_dirty = true, timeout = 3600]
  theories
    Moment_Jacobian

session Applied_Math_Nonemptiness in "." = Applied_Math_MomentJac +
  options [document = false, quick_and_dirty = true, timeout = 3600]
  sessions
    Applied_Math_BlockDet
    Applied_Math_MomentJac
  theories
    Nonemptiness_Paper

(* The robust-feasible-set development is split for build granularity:
   Nonemptiness_Robust1 (the long, stable first half) bakes into the
   Applied_Math_Appendix_Base heap; Nonemptiness_Robust2 (the Sym^2 T
   diagonal moment laws, formerly a parse-time hotspot) sits alone in the
   Applied_Math_Appendix leaf so it can be rebuilt/iterated in minutes;
   Nonemptiness_Robust3 is the stable M5 scaffold heap; and
   Nonemptiness_Robust4 is the live F0 frontier theory. *)
session Applied_Math_Appendix_Base in "Appendix" = Applied_Math_Nonemptiness +
  options [document = false, quick_and_dirty = true, timeout = 3600]
  sessions
    Applied_Math_HigherDiff
  theories
    Nonemptiness_Regnonzero_Appendix
    Nonemptiness_Capstone
    Nonemptiness_Robust1

session Applied_Math_Appendix in "Appendix/Robust2" = Applied_Math_Appendix_Base +
  options [document = false, quick_and_dirty = true, timeout = 3600]
  theories
    Nonemptiness_Robust2

session Applied_Math_Sard in "SardNegligible" = Applied_Math_Base +
  options [document = false, quick_and_dirty = true, timeout = 3600]
  sessions
    "HOL-Analysis"
  theories
    Sard_Negligible

(* Higher-order (k-times Fréchet) differentiability, ported from the
   Verified_Numerical_Algorithms project.  Parented directly on HOL-Analysis +
   the AFP's Smooth_Manifolds; deliberately independent of the Munkres/Jordan
   stack above, since these theories only need real-analysis. *)
session Applied_Math_HigherDiff in "HigherDiff" = "HOL-Analysis" +
  options [document = false, quick_and_dirty = true, timeout = 3600]
  sessions
    Smooth_Manifolds
  theories
    Limits_Higher_Order_Derivatives
    Auxiliary_Facts
    Higher_Differentiability
    Higher_Differentiability_Multi
    Taylor_Peano
    Ck1_C1_Bridge

(* M5 consolidation stable heap: Nonemptiness_Robust3 contains the checked
   upstream scaffold through the D3 cover set-algebra bridge.  The active F0
   frontier lives in the child session below, so jEdit can load this heap while
   editing the frontier theory rather than baking the target buffer into the
   active logic image. *)
session Applied_Math_Appendix_Full in "Appendix/Robust3" = Applied_Math_Appendix +
  options [document = false, quick_and_dirty = true, timeout = 3600]
  theories
    Nonemptiness_Robust3

(* Live frontier for the M5/F0 capstone.  This theory imports the stable
   Applied_Math_Appendix_Full heap and contains the remaining D3/D4 chart
   obligations plus the downstream F0_dip_nonempty target. *)
session Applied_Math_Appendix_Frontier in "Appendix/Robust4" = Applied_Math_Appendix_Full +
  options [document = false, quick_and_dirty = true, timeout = 3600]
  theories
    Nonemptiness_Robust4

(* Standalone real-analytic (C^omega) function theory + analytic IFT.  Foundational
   and reusable: parented only on the (Malta-synced) higher-derivative/Taylor stack,
   independent of the dipole/Robust development.  The dipole-specific bridge that
   applies the analytic IFT to discharge the D34 leaves lives in its own theory. *)
session Applied_Math_Analytic in "Analytic" = Applied_Math_HigherDiff +
  options [document = false, quick_and_dirty = true, timeout = 3600]
  sessions
    Smooth_Manifolds
  theories
    Real_Analytic
    Real_Analytic_Bump

(* The formal-series local inverse of a real-analytic map (majorant method): the purely
   real analytic core of the multivariate analytic inverse/implicit function theorem.
   Leaf on the Applied_Math_Analytic heap. *)
session Applied_Math_Analytic_Inverse in "Analytic/Inverse" = Applied_Math_Analytic +
  options [document = false, quick_and_dirty = true, timeout = 3600]
  theories
    Real_Analytic_Inverse

(* Complexification bridge: the several-variable Cauchy-Riemann criterion, holomorphic => real
   C^infinity, and real-analytic <=> local holomorphic extension (A1/A2/A3).  These are the
   verified foundation for the analytic IFT and the multivariate nowhere-dense workhorse.  It
   needs HOL-Complex_Analysis, so it sits in its own session on top of Applied_Math_Analytic. *)
session Applied_Math_Analytic_Complex in "Analytic/Complex" = Applied_Math_Analytic_Inverse +
  options [document = false, quick_and_dirty = true, timeout = 3600]
  sessions
    "HOL-Complex_Analysis"
  theories
    Real_Analytic_Complex
    Real_Analytic_IFT

(* The D34 analytic-bridge platform: ONE heap containing BOTH the robust nonemptiness
   development (through Nonemptiness_Robust2) AND the real-analytic stack (through the
   analytic IFT + the nowhere-dense-zeros workhorse).  Parented on the Appendix heap;
   the analytic-side theories are loaded from the Applied_Math_Analytic_Complex sources
   and baked in, so the dipole-specific D34 bridge can be edited interactively against
   this heap (and Robust3 can later import it to discharge the two chart-branch cores). *)
session Applied_Math_D34_Analytic in "Appendix/AnalyticBridge" = Applied_Math_Appendix +
  options [document = false, quick_and_dirty = true, timeout = 3600]
  sessions
    Applied_Math_Analytic_Complex
  theories
    D34_Analytic_Bridge
    D34_UPhi_Branch
    D34_H0res_Branch
